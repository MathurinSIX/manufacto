# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Square Checkout
# sandbox: each checkout calls CreatePaymentLink with the mapped catalog product;
#   Square shows a sandbox testing panel (normal). Test card: 4111 1111 1111 1111.
# production: catalog products use CreatePaymentLink. Every purchasable internal
#   product must be linked to a Square catalog variation in the admin Square tab.
SQUARE_ENVIRONMENT=sandbox
SQUARE_API_VERSION=2026-01-22
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_LOCATION_ID=your-square-location-id
SQUARE_WEBHOOK_URL=https://your-domain.com/api/square/webhook
SQUARE_WEBHOOK_SIGNATURE_KEY=your-square-webhook-signature-key
# Square app OAuth scopes needed: PAYMENTS_READ/WRITE (refunds on cancel), ORDERS_READ/WRITE,
# SUBSCRIPTIONS_READ/WRITE, CUSTOMERS_READ. Webhook events: payment.created,
# payment.updated, subscription.created
